      "pluginVersion": "10.0.0",
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{service=\"platform-api\",status=~\"5..\"}[5m])) / sum(rate(http_requests_total{service=\"platform-api\"}[5m])) * 100",
