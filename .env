# =============================================================================
# Video Processing Configuration
# =============================================================================
VIDEO_UPLOAD_MAX_SIZE=524288000  # 500MB in bytes
VIDEO_TRANSCODING_ENABLED=true
VIDEO_PRESETS=low,medium,high,4k
FFMPEG_PATH=/usr/bin/ffmpeg

# =============================================================================
# Email Configuration (SMTP)
# =============================================================================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=noreply@example.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=noreply@example.com
SMTP_FROM_NAME=VideoStreamGo

# =============================================================================
# Frontend Configuration
# =============================================================================
PUBLIC_API_URL=http://localhost:8080/v1
PUBLIC_INSTANCE_ID=platform
PUBLIC_SITE_NAME=VideoStreamGo
PUBLIC_SUPPORT_EMAIL=support@example.com

# =============================================================================
# Logging Configuration
# =============================================================================
LOG_LEVEL=debug  # debug, info, warn, error
LOG_FORMAT=json  # json, text

# =============================================================================
# Rate Limiting
# =============================================================================
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=1m

# =============================================================================
# Monitoring & Observability
# =============================================================================
METRICS_ENABLED=true
METRICS_PORT=9090
TRACING_ENABLED=false
TRACING_ENDPOINT=http://localhost:4317

# =============================================================================
# Feature Flags
# =============================================================================
FEATURE_COMMENTS_ENABLED=true
FEATURE_LIKES_ENABLED=true
FEATURE_SUBSCRIPTIONS_ENABLED=true
FEATURE_LIVE_STREAMING=false
FEATURE_MONETIZATION=true

# =============================================================================
# CDN Configuration
# =============================================================================
CDN_URL=https://cdn.videostreamgo.com
CDN_ENABLED=false

# =============================================================================
# Admin Configuration
# =============================================================================
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Nellee1988!
ADMIN_API_KEY=your-admin-api-key

# =============================================================================
# Development/Testing
# =============================================================================
TEST_DB_HOST=localhost
TEST_DB_PORT=5432
TEST_DB_USER=postgres
TEST_DB_PASSWORD=Nellee1988!
TEST_DB_NAME=videostreamgo_test

# =============================================================================
# HttpOnly cookies
# =============================================================================
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false
COOKIE_HTTPONLY=true
COOKIE_MAX_AGE=86400

