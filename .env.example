# =============================================================================
# VideoStreamGo Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values for your environment
# IMPORTANT: Change all placeholder values for production deployments!
# =============================================================================

# =============================================================================
# Database Configuration (PostgreSQL)
# =============================================================================
POSTGRES_USER=videostreamgo
POSTGRES_PASSWORD=change-this-to-a-secure-password
MASTER_DB_NAME=videostreamgo_master

# =============================================================================
# Redis Configuration
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=10

# =============================================================================
# MinIO (S3-compatible Storage) Configuration
# =============================================================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-this-to-a-secure-password

# =============================================================================
# Platform API Configuration
# =============================================================================
PLATFORM_API_PORT=8080
PLATFORM_API_ENV=development

# =============================================================================
# JWT Configuration
# =============================================================================
JWT_SECRET=change-this-to-a-secure-jwt-secret-minimum-32-characters
JWT_EXPIRY=24h
JWT_REFRESH_EXPIRY=168h

# =============================================================================
# Encryption Configuration (Required for production)
# =============================================================================
# AES-256 encryption key for sensitive data (e.g., tenant secrets)
# Must be at least 32 characters
ENCRYPTION_KEY=change-this-to-a-secure-encryption-key-minimum-32-characters

# =============================================================================
# Instance API Configuration
# =============================================================================
INSTANCE_API_PORT=8081
INSTANCE_API_ENV=development
INSTANCE_JWT_SECRET=change-this-to-a-secure-jwt-secret-minimum-32-characters
INSTANCE_JWT_EXPIRY=24h

# =============================================================================
# Stripe Configuration
# =============================================================================
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRICE_ID_MONTHLY=price_xxx
STRIPE_PRICE_ID_YEARLY=price_xxx

# =============================================================================
# Storage Configuration (S3-compatible)
# =============================================================================
S3_ENDPOINT=https://s3.amazonaws.com
S3_REGION=us-east-1
S3_BUCKET=videostreamgo
S3_USE_SSL=true
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_DEFAULT_REGION=us-east-1

# Alternative S3-compatible storage (e.g., MinIO, DigitalOcean Spaces)
# S3_ENDPOINT=https://nyc3.digitaloceanspaces.com
# S3_FORCE_PATH_STYLE=false

# =============================================================================
# Video Processing Configuration
# =============================================================================
VIDEO_UPLOAD_MAX_SIZE=524288000  # 500MB in bytes
VIDEO_TRANSCODING_ENABLED=true
VIDEO_PRESETS=low,medium,high,4k
FFMPEG_PATH=/usr/bin/ffmpeg

# =============================================================================
# Email Configuration (SMTP)
# =============================================================================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=noreply@example.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=noreply@example.com
SMTP_FROM_NAME=VideoStreamGo

# =============================================================================
# Frontend Configuration
# =============================================================================
# Vite uses PUBLIC_ prefix for env vars exposed to client-side code
# These must be defined for the frontend to work correctly
PUBLIC_PLATFORM_API_URL=http://localhost:8080
PUBLIC_INSTANCE_API_URL=http://localhost:8081
PUBLIC_API_URL=http://localhost:8080/v1
PUBLIC_INSTANCE_ID=platform
PUBLIC_SITE_NAME=VideoStreamGo
PUBLIC_SUPPORT_EMAIL=support@example.com

# =============================================================================
# Logging Configuration
# =============================================================================
LOG_LEVEL=debug  # debug, info, warn, error
LOG_FORMAT=json  # json, text

# =============================================================================
# Rate Limiting
# =============================================================================
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=1m

# =============================================================================
# Monitoring & Observability
# =============================================================================
METRICS_ENABLED=true
METRICS_PORT=9090
TRACING_ENABLED=false
TRACING_ENDPOINT=http://localhost:4317

# =============================================================================
# Feature Flags
# =============================================================================
FEATURE_COMMENTS_ENABLED=true
FEATURE_LIKES_ENABLED=true
FEATURE_SUBSCRIPTIONS_ENABLED=true
FEATURE_LIVE_STREAMING=false
FEATURE_MONETIZATION=true

# =============================================================================
# CDN Configuration
# =============================================================================
CDN_URL=https://cdn.videostreamgo.com
CDN_ENABLED=false

# =============================================================================
# Admin Configuration
# =============================================================================
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your-admin-password
ADMIN_API_KEY=your-admin-api-key

# =============================================================================
# CORS Configuration
# =============================================================================
# Comma-separated list of allowed origins for CORS
# For production, explicitly list all allowed origins (no wildcards)
# Example: https://example.com,https://app.example.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4321

# =============================================================================
# Development/Testing
# =============================================================================
TEST_DB_HOST=localhost
TEST_DB_PORT=5432
TEST_DB_USER=postgres
TEST_DB_PASSWORD=your-password
TEST_DB_NAME=videostreamgo_test
