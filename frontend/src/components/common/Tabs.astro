---
interface Tab {
  id: string;
  label: string;
  href?: string;
  count?: number;
}

interface Props {
  tabs: Tab[];
  activeTab: string;
  class?: string;
}

const { tabs, activeTab, class: className = '' } = Astro.props;
---

<div class={className}>
  <div class="border-b border-secondary-200 dark:border-secondary-700">
    <nav class="-mb-px flex space-x-8" aria-label="Tabs">
      {tabs.map((tab) => (
        <a
          href={tab.href || `#${tab.id}`}
          class:list={[
            'whitespace-nowrap border-b-2 py-4 px-1 text-sm font-medium transition-colors',
            activeTab === tab.id
              ? 'border-primary-500 text-primary-600 dark:text-primary-400'
              : 'border-transparent text-secondary-500 hover:border-secondary-300 hover:text-secondary-700 dark:hover:text-secondary-300'
          ]}
        >
          {tab.label}
          {tab.count !== undefined && (
            <span
              class:list={[
                'ml-2 rounded-full px-2 py-0.5 text-xs font-medium',
                activeTab === tab.id
                  ? 'bg-primary-100 text-primary-600 dark:bg-primary-900 dark:text-primary-300'
                  : 'bg-secondary-100 text-secondary-600 dark:bg-secondary-800 dark:text-secondary-400'
              ]}
            >
              {tab.count}
            </span>
          )}
        </a>
      ))}
    </nav>
  </div>

  <div class="mt-4">
    <slot />
  </div>
</div>
