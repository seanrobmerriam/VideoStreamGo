---
interface Props {
  src?: string;
  alt?: string;
  name?: string;
  size?: 'sm' | 'md' | 'lg' | 'xl';
  class?: string;
}

const {
  src,
  alt = '',
  name = '',
  size = 'md',
  class: className = '',
} = Astro.props;

const sizeClasses = {
  sm: 'h-8 w-8 text-xs',
  md: 'h-10 w-10 text-sm',
  lg: 'h-12 w-12 text-base',
  xl: 'h-16 w-16 text-lg',
};

const avatarClasses = [
  'rounded-full bg-secondary-200 dark:bg-secondary-700 flex items-center justify-center font-medium text-secondary-600 dark:text-secondary-400 overflow-hidden',
  sizeClasses[size],
  className,
].filter(Boolean).join(' ');

const getInitials = (name: string) => {
  return name
    .split(' ')
    .map((n) => n[0])
    .join('')
    .toUpperCase()
    .slice(0, 2);
};
---

{src ? (
  <img src={src} alt={alt || name} class={avatarClasses} />
) : (
  <div class={avatarClasses} title={name}>
    {name ? getInitials(name) : '?'}
  </div>
)}
