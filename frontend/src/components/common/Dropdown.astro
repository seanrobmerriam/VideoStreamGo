---
interface Props {
  trigger?: string;
  align?: 'left' | 'right';
  class?: string;
}

const { trigger = 'Options', align = 'right', class: className = '' } = Astro.props;

const alignClasses = {
  left: 'left-0',
  right: 'right-0',
};
---

<div class="relative inline-block">
  <button
    type="button"
    class="dropdown-trigger inline-flex items-center justify-center rounded-lg border border-secondary-200 bg-white dark:bg-secondary-800 px-4 py-2 text-sm font-medium text-secondary-700 dark:text-secondary-300 hover:bg-secondary-50 dark:hover:bg-secondary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2"
  >
    {trigger}
    <svg class="ml-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
    </svg>
  </button>

  <div
    class={`dropdown-menu absolute z-50 mt-2 w-48 origin-top-right rounded-lg bg-white dark:bg-secondary-800 shadow-lg ring-1 ring-black ring-opacity-5 focus:outline-none hidden ${alignClasses[align]} ${className}`}
  >
    <div class="py-1">
      <slot />
    </div>
  </div>
</div>

<script>
  document.querySelectorAll('.dropdown-trigger').forEach((button) => {
    const dropdown = button.nextElementSibling as HTMLElement;
    
    button.addEventListener('click', (e) => {
      e.stopPropagation();
      dropdown.classList.toggle('hidden');
    });
    
    document.addEventListener('click', () => {
      dropdown.classList.add('hidden');
    });
    
    dropdown.querySelectorAll('a, button').forEach((item) => {
      item.addEventListener('click', () => {
        dropdown.classList.add('hidden');
      });
    });
  });
</script>
