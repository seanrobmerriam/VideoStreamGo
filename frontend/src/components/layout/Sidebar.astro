---
interface Props {
  items?: { label: string; href: string; icon?: string }[];
  title?: string;
}

const { items = [], title = 'Menu' } = Astro.props;
---

<aside class="fixed left-0 top-0 z-40 h-screen w-64 border-r border-secondary-200 bg-white pt-16 transition-transform dark:border-secondary-800 dark:bg-secondary-950" id="sidebar">
  <div class="flex h-full flex-col">
    <div class="flex-1 overflow-y-auto px-3 py-4">
      {title && (
        <h3 class="mb-4 px-3 text-xs font-semibold uppercase tracking-wider text-secondary-500 dark:text-secondary-400">
          {title}
        </h3>
      )}
      <ul class="space-y-1">
        {items.map((item) => (
          <li>
            <a href={item.href} class="flex items-center gap-3 rounded-lg px-3 py-2 text-sm font-medium text-secondary-700 hover:bg-secondary-100 hover:text-primary-600 dark:text-secondary-300 dark:hover:bg-secondary-800 dark:hover:text-primary-400">
              {item.icon && <span class="h-5 w-5" set:html={item.icon} />}
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>
</aside>
