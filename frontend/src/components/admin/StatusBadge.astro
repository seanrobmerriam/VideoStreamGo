---
interface Props {
  status: 'active' | 'inactive' | 'pending' | 'processing' | 'published' | 'draft' | 'banned' | 'paused' | 'suspended' | 'provisioning';
  class?: string;
}

const { status, class: className = '' } = Astro.props;

const statusConfig: Record<string, { variant: 'success' | 'warning' | 'danger' | 'neutral' | 'primary'; label: string }> = {
  active: { variant: 'success', label: 'Active' },
  published: { variant: 'success', label: 'Published' },
  provisioning: { variant: 'warning', label: 'Provisioning' },
  processing: { variant: 'warning', label: 'Processing' },
  pending: { variant: 'warning', label: 'Pending' },
  paused: { variant: 'warning', label: 'Paused' },
  draft: { variant: 'neutral', label: 'Draft' },
  inactive: { variant: 'neutral', label: 'Inactive' },
  banned: { variant: 'danger', label: 'Banned' },
  suspended: { variant: 'danger', label: 'Suspended' },
};

const { variant, label } = statusConfig[status] || { variant: 'neutral' as const, label: status };

const variantClasses = {
  success: 'bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200',
  warning: 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-200',
  danger: 'bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-200',
  neutral: 'bg-secondary-100 text-secondary-800 dark:bg-secondary-700 dark:text-secondary-300',
  primary: 'bg-primary-100 text-primary-800 dark:bg-primary-900 dark:text-primary-200',
};
---

<span class:list={[
  'inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium',
  variantClasses[variant],
  className,
]}>
  {label}
</span>
