---
import BaseLayout from '@layouts/BaseLayout.astro';
import Sidebar from '@components/layout/Sidebar.astro';
import StatsCard from '@components/admin/StatsCard.astro';
import Button from '@components/common/Button.astro';

export function getStaticPaths() {
  return [
    { params: { subdomain: 'stream' } },
    { params: { subdomain: 'video' } },
    { params: { subdomain: 'watch' } },
  ];
}

const { subdomain } = Astro.params;
---

<BaseLayout title="Admin Dashboard - Video Site">
  <div class="flex h-screen bg-gray-100">
    <Sidebar activePath={`/instance/${subdomain}/admin`} />
    <main class="flex-1 overflow-y-auto p-8">
      <div class="flex justify-between items-center mb-8">
        <h1 class="text-2xl font-bold">Admin Dashboard</h1>
        <div class="flex gap-4">
          <a href={`/instance/${subdomain}`} target="_blank" class="text-indigo-600 hover:text-indigo-900 flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
            View Site
          </a>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
        <StatsCard title="Total Videos" value="156" trend="+12" />
        <StatsCard title="Total Views" value="45.2K" trend="+8%" />
        <StatsCard title="Subscribers" value="1,234" trend="+5%" />
        <StatsCard title="Storage Used" value="52 GB" trend="+3%" />
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <div class="bg-white rounded-lg shadow p-6">
          <h2 class="text-lg font-semibold mb-4">Quick Actions</h2>
          <div class="grid grid-cols-2 gap-4">
            <a href={`/instance/${subdomain}/admin/videos`} class="p-4 bg-indigo-50 rounded-lg text-center hover:bg-indigo-100">
              <p class="font-medium text-indigo-700">Manage Videos</p>
            </a>
            <a href={`/instance/${subdomain}/admin/categories`} class="p-4 bg-green-50 rounded-lg text-center hover:bg-green-100">
              <p class="font-medium text-green-700">Categories</p>
            </a>
            <a href={`/instance/${subdomain}/admin/users`} class="p-4 bg-yellow-50 rounded-lg text-center hover:bg-yellow-100">
              <p class="font-medium text-yellow-700">Users</p>
            </a>
            <a href={`/instance/${subdomain}/admin/settings`} class="p-4 bg-purple-50 rounded-lg text-center hover:bg-purple-100">
              <p class="font-medium text-purple-700">Settings</p>
            </a>
          </div>
        </div>

        <div class="bg-white rounded-lg shadow p-6">
          <h2 class="text-lg font-semibold mb-4">Recent Activity</h2>
          <div class="space-y-4">
            <div class="flex items-center justify-between py-2 border-b">
              <span class="text-sm text-gray-600">New video uploaded</span>
              <span class="text-xs text-gray-400">2 min ago</span>
            </div>
            <div class="flex items-center justify-between py-2 border-b">
              <span class="text-sm text-gray-600">New subscriber: John Doe</span>
              <span class="text-xs text-gray-400">15 min ago</span>
            </div>
            <div class="flex items-center justify-between py-2 border-b">
              <span class="text-sm text-gray-600">Comment on "Tutorial Video"</span>
              <span class="text-xs text-gray-400">1 hour ago</span>
            </div>
            <div class="flex items-center justify-between py-2">
              <span class="text-sm text-gray-600">View milestone: 10K views</span>
              <span class="text-xs text-gray-400">3 hours ago</span>
            </div>
          </div>
        </div>
      </div>
    </main>
  </div>
</BaseLayout>
