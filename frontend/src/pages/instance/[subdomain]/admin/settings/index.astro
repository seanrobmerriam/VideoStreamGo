---
import BaseLayout from '@layouts/BaseLayout.astro';
import Sidebar from '@components/layout/Sidebar.astro';
import Button from '@components/common/Button.astro';
import Input from '@components/common/Input.astro';
import Tabs from '@components/common/Tabs.astro';

export function getStaticPaths() {
  return [
    { params: { subdomain: 'stream' } },
    { params: { subdomain: 'video' } },
    { params: { subdomain: 'watch' } },
  ];
}

const { subdomain } = Astro.params;
---

<BaseLayout title="Settings - Admin">
  <div class="flex h-screen bg-gray-100">
    <Sidebar activePath={`/instance/${subdomain}/admin/settings`} />
    <main class="flex-1 overflow-y-auto p-8">
      <h1 class="text-2xl font-bold mb-8">Instance Settings</h1>

      <Tabs 
        tabs={[
          { id: 'general', label: 'General', active: true },
          { id: 'branding', label: 'Branding' },
          { id: 'features', label: 'Features' },
          { id: 'seo', label: 'SEO' }
        ]}
      >
        <div id="general" class="tab-content">
          <div class="bg-white rounded-lg shadow p-6 max-w-2xl">
            <h2 class="text-lg font-semibold mb-4">General Settings</h2>
            
            <div class="space-y-4">
              <div>
                <label for="instance_name" class="block text-sm font-medium text-gray-700 mb-1">Instance Name</label>
                <Input id="instance_name" name="instance_name" type="text" value="My Video Site" />
              </div>

              <div>
                <label for="subdomain" class="block text-sm font-medium text-gray-700 mb-1">Subdomain</label>
                <Input id="subdomain" name="subdomain" type="text" value={subdomain} disabled />
                <p class="text-xs text-gray-500 mt-1">Subdomain cannot be changed after creation</p>
              </div>

              <div>
                <label for="default_language" class="block text-sm font-medium text-gray-700 mb-1">Default Language</label>
                <select id="default_language" name="default_language" class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500">
                  <option value="en" selected>English</option>
                  <option value="es">Spanish</option>
                  <option value="fr">French</option>
                  <option value="de">German</option>
                </select>
              </div>

              <div>
                <label for="timezone" class="block text-sm font-medium text-gray-700 mb-1">Timezone</label>
                <select id="timezone" name="timezone" class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500">
                  <option value="UTC" selected>UTC</option>
                  <option value="America/New_York">Eastern Time</option>
                  <option value="America/Los_Angeles">Pacific Time</option>
                </select>
              </div>

              <div class="pt-4">
                <Button variant="primary">Save Changes</Button>
              </div>
            </div>
          </div>
        </div>

        <div id="branding" class="tab-content hidden">
          <div class="bg-white rounded-lg shadow p-6 max-w-2xl">
            <h2 class="text-lg font-semibold mb-4">Branding</h2>
            
            <div class="space-y-4">
              <div>
                <label for="site_title" class="block text-sm font-medium text-gray-700 mb-1">Site Title</label>
                <Input id="site_title" name="site_title" type="text" value="My Video Site" />
              </div>

              <div>
                <label for="site_description" class="block text-sm font-medium text-gray-700 mb-1">Site Description</label>
                <textarea 
                  id="site_description" 
                  name="site_description" 
                  rows="3" 
                  class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500"
                >Welcome to my video streaming site!</textarea>
              </div>

              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Logo</label>
                <div class="flex items-center gap-4">
                  <div class="w-16 h-16 bg-gray-100 rounded-lg flex items-center justify-center">
                    <svg class="w-8 h-8 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                    </svg>
                  </div>
                  <Button variant="outline">Upload Logo</Button>
                </div>
              </div>

              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Favicon</label>
                <div class="flex items-center gap-4">
                  <div class="w-8 h-8 bg-gray-100 rounded flex items-center justify-center">
                    <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                    </svg>
                  </div>
                  <Button variant="outline">Upload Favicon</Button>
                </div>
              </div>

              <div class="pt-4">
                <Button variant="primary">Save Changes</Button>
              </div>
            </div>
          </div>
        </div>

        <div id="features" class="tab-content hidden">
          <div class="bg-white rounded-lg shadow p-6 max-w-2xl">
            <h2 class="text-lg font-semibold mb-4">Features</h2>
            
            <div class="space-y-4">
              <div class="flex items-center justify-between py-3 border-b">
                <div>
                  <p class="font-medium">Allow User Registration</p>
                  <p class="text-sm text-gray-500">Let visitors create accounts on your site</p>
                </div>
                <input type="checkbox" checked class="h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-gray-300 rounded" />
              </div>

              <div class="flex items-center justify-between py-3 border-b">
                <div>
                  <p class="font-medium">Enable Comments</p>
                  <p class="text-sm text-gray-500">Allow users to comment on videos</p>
                </div>
                <input type="checkbox" checked class="h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-gray-300 rounded" />
              </div>

              <div class="flex items-center justify-between py-3 border-b">
                <div>
                  <p class="font-medium">Enable Ratings</p>
                  <p class="text-sm text-gray-500">Allow users to like/rate videos</p>
                </div>
                <input type="checkbox" checked class="h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-gray-300 rounded" />
              </div>

              <div class="flex items-center justify-between py-3 border-b">
                <div>
                  <p class="font-medium">Live Streaming</p>
                  <p class="text-sm text-gray-500">Enable live streaming capabilities</p>
                </div>
                <input type="checkbox" class="h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-gray-300 rounded" />
              </div>

              <div class="flex items-center justify-between py-3">
                <div>
                  <p class="font-medium">Download Videos</p>
                  <p class="text-sm text-gray-500">Allow users to download videos</p>
                </div>
                <input type="checkbox" class="h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-gray-300 rounded" />
              </div>

              <div class="pt-4">
                <Button variant="primary">Save Changes</Button>
              </div>
            </div>
          </div>
        </div>

        <div id="seo" class="tab-content hidden">
          <div class="bg-white rounded-lg shadow p-6 max-w-2xl">
            <h2 class="text-lg font-semibold mb-4">SEO Settings</h2>
            
            <div class="space-y-4">
              <div>
                <label for="meta_title" class="block text-sm font-medium text-gray-700 mb-1">Meta Title</label>
                <Input id="meta_title" name="meta_title" type="text" placeholder="My Video Site - Watch Videos Online" />
              </div>

              <div>
                <label for="meta_description" class="block text-sm font-medium text-gray-700 mb-1">Meta Description</label>
                <textarea 
                  id="meta_description" 
                  name="meta_description" 
                  rows="3" 
                  class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500"
                  placeholder="Description for search engines..."
                ></textarea>
              </div>

              <div>
                <label for="keywords" class="block text-sm font-medium text-gray-700 mb-1">Keywords</label>
                <Input id="keywords" name="keywords" type="text" placeholder="video, streaming, watch, videos" />
              </div>

              <div class="pt-4">
                <Button variant="primary">Save Changes</Button>
              </div>
            </div>
          </div>
        </div>
      </Tabs>
    </main>
  </div>
</BaseLayout>

<script>
  const tabButtons = document.querySelectorAll('[data-tab]');
  const tabContents = document.querySelectorAll('.tab-content');

  tabButtons.forEach(button => {
    button.addEventListener('click', () => {
      const tabId = button.getAttribute('data-tab');
      
      tabButtons.forEach(btn => btn.classList.remove('border-indigo-600', 'text-indigo-600'));
      tabButtons.forEach(btn => btn.classList.add('border-transparent', 'text-gray-500'));
      
      button.classList.remove('border-transparent', 'text-gray-500');
      button.classList.add('border-indigo-600', 'text-indigo-600');
      
      tabContents.forEach(content => {
        content.classList.add('hidden');
      });
      
      document.getElementById(tabId || '')?.classList.remove('hidden');
    });
  });
</script>
