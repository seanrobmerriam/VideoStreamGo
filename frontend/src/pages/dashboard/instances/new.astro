---
import BaseLayout from '@layouts/BaseLayout.astro';
import Sidebar from '@components/layout/Sidebar.astro';
import Button from '@components/common/Button.astro';
import Input from '@components/common/Input.astro';
---

<BaseLayout title="Create Instance - VideoStreamGo">
  <div class="flex h-screen bg-gray-100">
    <Sidebar />
    <main class="flex-1 overflow-y-auto p-8">
      <h1 class="text-2xl font-bold mb-8">Create New Instance</h1>

      <div class="max-w-2xl">
        <form class="space-y-6">
          <div class="bg-white rounded-lg shadow p-6">
            <h2 class="text-lg font-semibold mb-4">Instance Details</h2>
            
            <div class="space-y-4">
              <div>
                <label for="name" class="block text-sm font-medium text-gray-700 mb-1">Instance Name</label>
                <Input id="name" name="name" type="text" placeholder="My Video Site" required />
              </div>

              <div>
                <label for="subdomain" class="block text-sm font-medium text-gray-700 mb-1">Subdomain</label>
                <div class="flex">
                  <Input 
                    id="subdomain" 
                    name="subdomain" 
                    type="text" 
                    placeholder="myvideos" 
                    required 
                    class="rounded-r-none"
                  />
                  <span class="inline-flex items-center px-3 border border-l-0 border-gray-300 bg-gray-50 text-gray-500 text-sm rounded-r-md">
                    .videostreamgo.com
                  </span>
                </div>
              </div>

              <div>
                <label for="plan" class="block text-sm font-medium text-gray-700 mb-1">Plan</label>
                <select id="plan" name="plan" class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500">
                  <option value="starter">Starter - $9/month</option>
                  <option value="pro" selected>Pro - $29/month</option>
                  <option value="enterprise">Enterprise - $99/month</option>
                </select>
              </div>
            </div>
          </div>

          <div class="bg-white rounded-lg shadow p-6">
            <h2 class="text-lg font-semibold mb-4">Branding</h2>
            
            <div class="space-y-4">
              <div>
                <label for="title" class="block text-sm font-medium text-gray-700 mb-1">Site Title</label>
                <Input id="title" name="title" type="text" placeholder="My Video Site" />
              </div>

              <div>
                <label for="description" class="block text-sm font-medium text-gray-700 mb-1">Description</label>
                <textarea 
                  id="description" 
                  name="description" 
                  rows="3" 
                  class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500"
                  placeholder="A brief description of your video site..."
                ></textarea>
              </div>
            </div>
          </div>

          <div class="flex gap-4">
            <Button variant="primary" type="submit">Create Instance</Button>
            <Button variant="outline" href="/dashboard/instances">Cancel</Button>
          </div>
        </form>
      </div>
    </main>
  </div>
</BaseLayout>
