---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/common/Button.astro';
import Card from '../components/common/Card.astro';
import Badge from '../components/common/Badge.astro';

const plans = [
  {
    name: 'Starter',
    price: '$29',
    period: '/month',
    description: 'Perfect for getting started with your video platform.',
    features: [
      'Up to 100 videos',
      '10GB storage',
      'Basic analytics dashboard',
      'Email support',
      'Custom branding colors',
      'Standard player controls',
    ],
    cta: 'Start Free Trial',
    popular: false,
  },
  {
    name: 'Professional',
    price: '$99',
    period: '/month',
    description: 'For growing businesses that need more power.',
    features: [
      'Up to 1,000 videos',
      '100GB storage',
      'Advanced analytics & insights',
      'Priority email support',
      'Custom domain',
      'API access',
      'No VideoStreamGo watermark',
      'Custom player branding',
    ],
    cta: 'Start Free Trial',
    popular: true,
  },
  {
    name: 'Business',
    price: '$299',
    period: '/month',
    description: 'For businesses with high traffic needs.',
    features: [
      'Up to 10,000 videos',
      '1TB storage',
      'Real-time analytics',
      'Phone & email support',
      'Multiple subdomains',
      'Full API access',
      'White-label license',
      'Custom integrations',
      'SLA guarantee',
    ],
    cta: 'Contact Sales',
    popular: false,
  },
  {
    name: 'Enterprise',
    price: 'Custom',
    period: '',
    description: 'For large organizations with custom requirements.',
    features: [
      'Unlimited videos',
      'Unlimited storage',
      'Dedicated analytics',
      '24/7 dedicated support',
      'White-label license',
      'Custom SLA',
      'On-premise option',
      'Dedicated account manager',
      'Custom development',
    ],
    cta: 'Contact Sales',
    popular: false,
  },
];

const faqs = [
  {
    question: 'Can I cancel my subscription anytime?',
    answer: 'Yes, you can cancel your subscription at any time. Your access will continue until the end of your billing period.',
  },
  {
    question: 'What payment methods do you accept?',
    answer: 'We accept all major credit cards (Visa, MasterCard, American Express) as well as PayPal and wire transfers for annual plans.',
  },
  {
    question: 'Can I upgrade my plan later?',
    answer: 'Absolutely! You can upgrade your plan at any time. The prorated difference will be charged to your account.',
  },
  {
    question: 'Is there a free trial?',
    answer: 'Yes, all paid plans come with a 14-day free trial. No credit card required to start.',
  },
  {
    question: 'What happens when I exceed my plan limits?',
    answer: 'We\'ll notify you when you\'re approaching your limits. You can upgrade your plan or purchase additional storage and video slots.',
  },
  {
    question: 'Do you offer discounts for nonprofits?',
    answer: 'Yes! We offer a 50% discount for registered nonprofits and educational institutions. Contact sales for more information.',
  },
];
---

<BaseLayout title="Pricing" description="Simple, transparent pricing for VideoStreamGo">
  <section class="py-16 sm:py-24">
    <div class="container mx-auto px-4">
      <div class="mx-auto max-w-2xl text-center">
        <h1 class="section-title">Simple, Transparent Pricing</h1>
        <p class="section-subtitle">Choose the plan that's right for you. All plans include a 14-day free trial.</p>
      </div>

      <!-- Pricing cards -->
      <div class="mx-auto mt-16 max-w-7xl">
        <div class="grid gap-8 lg:grid-cols-2 xl:grid-cols-4">
          {plans.map((plan) => (
            <Card class:list={[
              'relative flex flex-col',
              plan.popular ? 'border-primary-500 ring-2 ring-primary-500/20' : ''
            ]}>
              {plan.popular && (
                <Badge variant="primary" class="absolute -top-3 left-1/2 -translate-x-1/2">Most Popular</Badge>
              )}
              <div class="text-center pb-6 border-b border-secondary-200 dark:border-secondary-700">
                <h3 class="text-xl font-semibold">{plan.name}</h3>
                <p class="mt-2 text-sm text-secondary-600 dark:text-secondary-400">{plan.description}</p>
                <div class="mt-4 flex items-baseline justify-center gap-1">
                  <span class="text-4xl font-bold text-secondary-900 dark:text-secondary-100">{plan.price}</span>
                  <span class="text-secondary-500">{plan.period}</span>
                </div>
              </div>
              <ul class="flex-1 space-y-3 py-6">
                {plan.features.map((feature) => (
                  <li class="flex items-start gap-2 text-sm">
                    <svg class="h-5 w-5 text-green-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                    </svg>
                    <span class="text-secondary-700 dark:text-secondary-300">{feature}</span>
                  </li>
                ))}
              </ul>
              <div class="pt-6 border-t border-secondary-200 dark:border-secondary-700">
                <Button variant={plan.popular ? 'primary' : 'outline'} fullWidth href={plan.name === 'Enterprise' ? '/contact' : '/signup'}>
                  {plan.cta}
                </Button>
              </div>
            </Card>
          ))}
        </div>
      </div>

      <!-- FAQ Section -->
      <div class="mx-auto mt-24 max-w-3xl">
        <h2 class="text-2xl font-bold text-center mb-12">Frequently Asked Questions</h2>
        <div class="space-y-6">
          {faqs.map((faq) => (
            <Card>
              <h3 class="font-semibold text-lg">{faq.question}</h3>
              <p class="mt-2 text-secondary-600 dark:text-secondary-400">{faq.answer}</p>
            </Card>
          ))}
        </div>
      </div>

      <!-- CTA -->
      <div class="mt-24 text-center">
        <h2 class="text-2xl font-bold">Still have questions?</h2>
        <p class="mt-4 text-secondary-600 dark:text-secondary-400">Our team is here to help you find the perfect plan.</p>
        <div class="mt-6">
          <Button href="/contact" variant="outline">Contact Sales</Button>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
